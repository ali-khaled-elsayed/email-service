# Docker environment — restore local dev from .env.local.backup
APP_NAME="Email Service"
APP_ENV=production
APP_KEY=base64:J7nHWaJkxMiepT1+kpNtbzg5BiDkO7Quj8XTtuN69TE=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=email_service
DB_USERNAME=email_service
DB_PASSWORD=docker_db_secret

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=docker_redis_secret
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

CACHE_STORE=redis
SESSION_DRIVER=database
SESSION_SECURE_COOKIE=false
QUEUE_CONNECTION=redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Mail (configure for your provider / Mailtrap)
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

WAIT_FOR_DB=true
WAIT_FOR_REDIS=true
RUN_MIGRATIONS=true
RUN_SEEDERS=true
OPTIMIZE_ON_BOOT=true

QUEUE_WORKERS_HIGH=2
QUEUE_WORKERS_DEFAULT=2
QUEUE_WORKERS_LOW=1
QUEUE_WORKERS_BULK=2
QUEUE_WORKERS_RETRY=1

EMAIL_SERVICE_MAX_ATTEMPTS=5
EMAIL_API_RATE_LIMIT=120
EMAIL_TRACKING_ENABLED=true
EMAIL_HEALTH_CHECK_INTERVAL=5
EMAIL_ATTACHMENTS_DISK=local

MYSQL_ROOT_PASSWORD=docker_root_secret
MYSQL_DATABASE=email_service
MYSQL_USER=email_service
MYSQL_PASSWORD=docker_db_secret

HTTP_PORT=80
